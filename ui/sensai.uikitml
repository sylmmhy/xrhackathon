<style>
  .panel-container {
    align-items: center;
    padding: 2;
    width: 50;
    display: flex;
    flex-direction: column;
  }

  .logo {
    width: 48;
    height: 18;
    object-fit: contain;
    margin-bottom: 1;
  }

  .btn {
    width: 66%;
    margin-top: 1;
    border-radius: 2;
    border-width: 0;
    font-size: 2.5;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    flex-direction: row;
    align-items: center;
    padding-top: 1.5;
    padding-bottom: 1.5;
    padding-left: 1.5;
    padding-right: 4;
  }

  .btn-icon {
    width: 4;
    height: 4;
    object-fit: contain;
    margin-left: 2;
  }

  #rain-button {
    background-color: #6d28d9;
    color: #ffffff;
  }

  #photo-button {
    background-color: #0ea5e9;
    color: #ffffff;
  }

  #world-button {
    background-color: #10b981;
    color: #ffffff;
  }

</style>
<div class="panel-container">
  <img src="/Yume.png" alt="YUME" class="logo" />
  <button id="rain-button" class="btn">
    <img src="/icons/rain-white.png" class="btn-icon" />
    Rain Toys
  </button>
  <button id="photo-button" class="btn">
    <img src="/icons/camera-white.png" class="btn-icon" />
    Photo 0/6
  </button>
  <button id="world-button" class="btn">
    <img src="/icons/earth-white.png" class="btn-icon" />
    Next World
  </button>
</div>
